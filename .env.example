# PostgreSQL
# Single DB: Airflow metadata + cryptoflow app tables both live here.
# init.sql creates the market_data table on first boot.
POSTGRES_USER=cryptoflow
POSTGRES_PASSWORD=admin
POSTGRES_DB=cryptoflow
CRYPTO_DB=cryptoflow

# Binance API 
# 1h interval × 1000 bars = 1000 unique hourly records per symbol per run
BINANCE_INTERVAL=1h
BINANCE_LIMIT=1000

# pgAdmin
PGADMIN_EMAIL=admin@cryptoflow.com
PGADMIN_PASSWORD=admin

# Airflow
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_FERNET_KEY=7nz1uSY528EnJpkblWFAquFJzc0K46ra0sKERdh6d-k=
AIRFLOW_WEBSERVER_SECRET_KEY=admin

# Elasticsearch / Kibana
ELASTIC_PASSWORD=admin
KIBANA_PASSWORD=admin

COMPOSE_PROJECT_NAME=cryptoflow_final
