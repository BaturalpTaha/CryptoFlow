# ─── PostgreSQL ───────────────────────────────────────
# Single DB: Airflow metadata + cryptoflow app tables both live here.
# init.sql creates the market_data table on first boot.
POSTGRES_USER=cryptoflow
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cryptoflow
CRYPTO_DB=cryptoflow

# ─── Binance API ──────────────────────────────────────
# 1h interval × 1000 bars = 1000 unique hourly records per symbol per run
BINANCE_INTERVAL=1h
BINANCE_LIMIT=1000

# ─── pgAdmin ──────────────────────────────────────────
PGADMIN_EMAIL=admin@cryptoflow.com
PGADMIN_PASSWORD=CHANGE_ME

# ─── Airflow ──────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME
AIRFLOW_FERNET_KEY=GENERATE_WITH_python3_-c_"from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_WEBSERVER_SECRET_KEY=CHANGE_ME

# ─── Elasticsearch / Kibana ───────────────────────────
ELASTIC_PASSWORD=CHANGE_ME
KIBANA_PASSWORD=CHANGE_ME
